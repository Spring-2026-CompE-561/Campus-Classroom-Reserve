# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database (matches docker-compose.yaml defaults) ---
POSTGRES_USER=ccr_user
POSTGRES_PASSWORD=ccr_password
POSTGRES_DB=campus_classroom_reserve

DATABASE_URL=postgresql://ccr_user:ccr_password@localhost:5432/campus_classroom_reserve

# --- JWT Auth ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
